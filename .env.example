# ── Environment ──────────────────────────────────────────────────────────────
ENV=development
DEBUG=true

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+pg8000://streetsat:streetsat_dev@localhost:5433/streetsat_db
DATABASE_POOL_SIZE=5
DATABASE_ECHO=false

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6380
REDIS_CACHE_TTL=3600

# ── RabbitMQ / Celery ─────────────────────────────────────────────────────────
RABBITMQ_URL=amqp://guest:guest@localhost:5672/
CELERY_BROKER_URL=amqp://guest:guest@localhost:5672/
CELERY_RESULT_BACKEND=redis://localhost:6379

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGODB_URL=mongodb://admin:admin_dev@localhost:27017/

# ── AWS (LocalStack em dev) ───────────────────────────────────────────────────
AWS_ENDPOINT_URL=http://localhost:4566
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_REGION=us-east-1
S3_BUCKET=streetsat-models-dev
SNS_TOPIC_ARN=arn:aws:sns:us-east-1:000000000000:streetsat-alerts-dev
SQS_SCRAPING_QUEUE_URL=http://localhost:4566/000000000000/streetsat-scraping-dev
SQS_INFERENCE_QUEUE_URL=http://localhost:4566/000000000000/streetsat-inference-dev
SQS_ALERTS_QUEUE_URL=http://localhost:4566/000000000000/streetsat-alerts-dev
RISK_THRESHOLD=2

# ── APIs ──────────────────────────────────────────────────────────────────────
NASA_API_KEY=DEMO_KEY

# ── Feature Flags ─────────────────────────────────────────────────────────────
COMPREHEND_ENABLED=false
USE_LOCALSTACK=true

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=DEBUG
LOG_FORMAT=console

# ── Dashboard ─────────────────────────────────────────────────────────────────
DASH_PORT=5000
DASH_HOST=0.0.0.0
API_BASE_URL=http://localhost:8000
